[
  {
    "UpdateStageName": "SteamCMD Download",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "FetchURL",
    "UpdateSourceData": "https://steamcdn-a.akamaihd.net/client/installer/steamcmd.zip",
    "UpdateSourceTarget": "{{$FullRootDir}}",
    "UpdateSourceArgs": "steamcmd.zip",
    "OverwriteExistingFiles": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "SteamCMD Extract",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "ExtractArchive",
    "UpdateSourceData": "{{$FullRootDir}}steamcmd.zip",
    "UpdateSourceTarget": "{{$FullRootDir}}",
    "OverwriteExistingFiles": true,
    "DeleteAfterExtract": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Battalion Legacy Dedicated Server Download",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "Executable",
    "UpdateSourceData": "cmd.exe",
    "UpdateSourceArgs": "/C \"\"{{$FullRootDir}}steamcmd.exe\" +login anonymous +force_install_dir \"{{$FullBaseDir}}\" +app_update 805140 +quit\"",
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Create root steam_appid.txt",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "CreateFile",
    "UpdateSourceData": "489940",
    "UpdateSourceArgs": "{{$FullRootDir}}steam_appid.txt",
    "OverwriteExistingFiles": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Create server steam_appid.txt",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "CreateFile",
    "UpdateSourceData": "489940",
    "UpdateSourceArgs": "{{$FullBaseDir}}steam_appid.txt",
    "OverwriteExistingFiles": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Create Win64 steam_appid.txt",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "CreateFile",
    "UpdateSourceData": "489940",
    "UpdateSourceArgs": "{{$FullBaseDir}}Battalion\\Binaries\\Win64\\steam_appid.txt",
    "OverwriteExistingFiles": true,
    "SkipOnFailure": false
  },
  {
    "UpdateStageName": "Verify Battalion executable",
    "UpdateSourcePlatform": "Windows",
    "UpdateSource": "Executable",
    "UpdateSourceData": "cmd.exe",
    "UpdateSourceArgs": "/C if exist \"{{$FullBaseDir}}BattalionServer.exe\" (exit /b 0) else (echo BattalionServer.exe not found in {{$FullBaseDir}} & exit /b 1)",
    "SkipOnFailure": false
  }
]
